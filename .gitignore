# .gitignore — Clockstopper Android project
# ─────────────────────────────────────────

# ── Gradle build outputs ──────────────────────────────────────────────────────
.gradle/
build/
app/build/

# ── Local configuration (machine-specific; must not be committed) ─────────────
local.properties

# ── Android Studio IDE files ──────────────────────────────────────────────────
*.iml
.idea/
*.iws
*.ipr

# ── macOS filesystem artefacts ────────────────────────────────────────────────
.DS_Store

# ── Kotlin / Java compilation outputs ────────────────────────────────────────
*.class
*.jar
*.aar

# ── Keystore files (never commit signing keys) ────────────────────────────────
*.jks
*.keystore

# ── Captured test results / reports ──────────────────────────────────────────
app/src/androidTest/results/
app/build/reports/
