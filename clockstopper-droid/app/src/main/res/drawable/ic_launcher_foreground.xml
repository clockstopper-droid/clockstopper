<?xml version="1.0" encoding="utf-8"?>
<!--
    Simple stopwatch / clock vector used as the launcher icon foreground.
    All paths are drawn within the standard 108 × 108 dp safe-zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer circle (watch face) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,18
            a36,36 0 1,0 0.001,0
            Z" />

    <!-- Hour hand -->
    <path
        android:fillColor="#212121"
        android:pathData="M52,30 L56,30 L56,54 L52,54 Z" />

    <!-- Minute hand -->
    <path
        android:fillColor="#212121"
        android:pathData="M54,52 L68,38 L70,41 L56,55 Z" />

    <!-- Centre dot -->
    <path
        android:fillColor="#212121"
        android:pathData="M54,51
            a3,3 0 1,0 0.001,0
            Z" />

</vector>
