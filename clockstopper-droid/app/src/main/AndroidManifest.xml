<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet permission required for any remote resources loaded by the WebView -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Keep screen on while the stopwatch is running -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClockStopper"
        android:usesCleartextTraffic="false">

        <!--
            Root launcher Activity.

            android:configChanges — we handle orientation and keyboard-availability
            ourselves so the WebView is NOT recreated on those events (avoids a
            full page reload every time the soft keyboard appears / the device
            is rotated while the stopwatch is running).

            android:windowSoftInputMode="adjustResize" — the WebView viewport
            shrinks to make room for the soft keyboard rather than being
            obscured by it.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize|uiMode"
            android:windowSoftInputMode="adjustResize">

            <!-- Designate this Activity as the application entry-point -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

    </application>

</manifest>
