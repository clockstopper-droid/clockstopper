# .gitignore — Global Time Clock (clockstopper)
# ─────────────────────────────────────────────
# This is a static web project (HTML5 / CSS3 / Vanilla JS).
# No build step, no package manager, no framework required.

# ── macOS filesystem artefacts ────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows filesystem artefacts ─────────────────────────────────────────────
Thumbs.db
Thumbs.db:encdata
Desktop.ini
$RECYCLE.BIN/

# ── Linux filesystem artefacts ───────────────────────────────────────────────
*~

# ── Editor / IDE directories ──────────────────────────────────────────────────
# VS Code
.vscode/

# JetBrains IDEs (IntelliJ IDEA, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim swap and backup files
*.swp
*.swo
*.swn
Session.vim

# Emacs lock files and backups
\#*\#
.\#*

# Sublime Text project files
*.sublime-project
*.sublime-workspace

# ── Node / npm (no tooling required, but guard against accidental installs) ───
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.pnp/
.pnp.js

# ── Build / dist output (guard against tooling experiments) ──────────────────
dist/
build/
out/
.cache/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Test artefacts ────────────────────────────────────────────────────────────
# Coverage reports, if a contributor wires up a coverage tool
coverage/
.nyc_output/
