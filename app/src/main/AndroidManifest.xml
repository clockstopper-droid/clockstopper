<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml
    ───────────────────
    Declares the application package, required permissions, and the single
    launcher Activity that hosts the Jetpack Navigation graph.

    Permissions
    ───────────
    INTERNET             — required if the stopwatch ever loads remote assets.
    WAKE_LOCK            — prevents CPU sleep while stopwatch is active.
    RECORD_AUDIO         — microphone access for call audio via MediaDevices API.
    MODIFY_AUDIO_SETTINGS— required to route audio to Bluetooth / wired headset
                           and to request audio focus via AudioManager.
    BLUETOOTH            — legacy Bluetooth permission (API < 31).
    BLUETOOTH_CONNECT    — runtime Bluetooth permission (API 31+); needed to
                           enumerate connected Bluetooth audio devices and
                           communicate with AudioDeviceCallback results.
    MANAGE_MEDIA         — allows the app to manage the media session and
                           respond to Bluetooth headset media-button events.
-->
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.clockstopper.app">

    <!-- ─────────────────────────────────────────────────────────────────── -->
    <!--  Permissions                                                         -->
    <!-- ─────────────────────────────────────────────────────────────────── -->

    <!-- Network access -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Screen / CPU wake-lock while running -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Microphone — for WebView MediaDevices.getUserMedia() call audio -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Audio routing — required to switch output to BT / wired headset -->
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Bluetooth (API < 31) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />

    <!-- Bluetooth runtime permissions (API 31+) -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_CONNECT"
        android:minSdkVersion="31" />

    <!-- Media session / headset button handling -->
    <uses-permission android:name="android.permission.MANAGE_MEDIA" />

    <!-- ─────────────────────────────────────────────────────────────────── -->
    <!--  Hardware feature declarations (not required; soft declarations)     -->
    <!-- ─────────────────────────────────────────────────────────────────── -->
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.microphone"
        android:required="false" />

    <!-- ─────────────────────────────────────────────────────────────────── -->
    <!--  Application                                                          -->
    <!-- ─────────────────────────────────────────────────────────────────── -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ClockStopper"
        android:usesCleartextTraffic="false">

        <!--
            MainActivity
            ────────────
            The sole Activity in this single-Activity application.

            exported="true" is required on API 31+ for Activities that carry
            a MAIN / LAUNCHER intent-filter.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|smallestScreenSize|uiMode"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                Receive Bluetooth headset media-button broadcasts so that
                play/pause/next/previous hardware keys on BT headsets are
                delivered to this Activity when the app holds an active
                MediaSession.
            -->
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>

        </activity>

        <!--
            MediaButtonReceiver — forwards headset/Bluetooth media button
            intents to the active MediaSessionCompat so the JS layer can
            receive play/pause/end-call commands from BT headset buttons.
        -->
        <receiver android:name="androidx.media.session.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
