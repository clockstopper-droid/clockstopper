<?xml version="1.0" encoding="utf-8"?>
<!--
    item_lap.xml
    ────────────
    Row layout for a single lap entry in the RecyclerView of StopwatchFragment.

    Three columns (left → right):
    ┌──────────────┬─────────────────┬─────────────────┐
    │  Lap N       │   Split time    │  Cumulative     │
    │  tv_lap_num  │   tv_lap_split  │  tv_lap_cumul.  │
    └──────────────┴─────────────────┴─────────────────┘

    - tv_lap_number       Left-aligned label, e.g. "Lap 3"
    - tv_lap_split        Center-aligned split duration, e.g. "00:12.34"
    - tv_lap_cumulative   Right-aligned cumulative time,  e.g. "01:05.67"

    All time displays use a monospace typeface to prevent width jitter.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical">

    <!-- Lap number label -->
    <TextView
        android:id="@+id/tv_lap_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:gravity="start"
        android:textColor="@color/lap_number_text"
        android:textSize="14sp"
        tools:text="Lap 3" />

    <!-- Split time -->
    <TextView
        android:id="@+id/tv_lap_split"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="monospace"
        android:gravity="center"
        android:textColor="@color/lap_time_text"
        android:textSize="14sp"
        tools:text="00:12.34" />

    <!-- Cumulative time -->
    <TextView
        android:id="@+id/tv_lap_cumulative"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="monospace"
        android:gravity="end"
        android:textColor="@color/lap_cumulative_text"
        android:textSize="14sp"
        tools:text="01:05.67" />

</LinearLayout>
