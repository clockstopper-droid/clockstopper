<?xml version="1.0" encoding="utf-8"?>
<!--
    Root layout for MainActivity.

    A ConstraintLayout root gives future child views a flexible, flat
    hierarchy to anchor against without extra nesting.  For now a single
    FragmentContainerView fills the entire screen; this is the recommended
    host for Fragment transactions because it correctly handles animation
    Z-ordering and back-stack transitions that a plain FrameLayout does not.

    The ID "fragmentContainer" is referenced whenever a Fragment transaction
    targets this container (e.g. supportFragmentManager.commit { replace(…) }).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
