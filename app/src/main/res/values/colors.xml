<?xml version="1.0" encoding="utf-8"?>
<!--
    colors.xml
    ──────────
    Colour palette for Clockstopper.

    Design intent
    ─────────────
    Dark background with high-contrast time display — optimised for readability
    in bright outdoor conditions (a typical stopwatch use case).

    Semantic tokens
    ───────────────
    background          — activity / fragment window background
    elapsed_time_text   — the large MM:SS.cc display
    lap_number_text     — "Lap N" label in each row
    lap_time_text       — split time in each lap row
    lap_cumulative_text — cumulative time in each lap row

    Material / theme tokens required by themes.xml
    ───────────────────────────────────────────────
    colorPrimary, colorPrimaryVariant, colorOnPrimary,
    colorSecondary, colorOnSecondary, colorBackground, colorSurface,
    colorOnBackground, colorOnSurface — standard Material Design role names
-->
<resources>

    <!-- ── Brand palette ──────────────────────────────────────────────────── -->
    <color name="colorPrimary">#1565C0</color>          <!-- Deep Blue 800   -->
    <color name="colorPrimaryVariant">#003c8f</color>   <!-- Deep Blue 900+  -->
    <color name="colorOnPrimary">#FFFFFF</color>

    <color name="colorSecondary">#00ACC1</color>        <!-- Cyan 600        -->
    <color name="colorOnSecondary">#000000</color>

    <!-- ── Surface / background ───────────────────────────────────────────── -->
    <color name="colorBackground">#121212</color>       <!-- Near-black      -->
    <color name="colorSurface">#1E1E1E</color>
    <color name="colorOnBackground">#FFFFFF</color>
    <color name="colorOnSurface">#FFFFFF</color>

    <!-- ── Semantic UI tokens ─────────────────────────────────────────────── -->
    <color name="background">#121212</color>
    <color name="elapsed_time_text">#FFFFFF</color>
    <color name="lap_number_text">#BDBDBD</color>       <!-- Grey 400        -->
    <color name="lap_time_text">#FFFFFF</color>
    <color name="lap_cumulative_text">#9E9E9E</color>   <!-- Grey 500        -->

</resources>
