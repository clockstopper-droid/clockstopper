<?xml version="1.0" encoding="utf-8"?>
<!--
    strings.xml
    ───────────
    All user-visible strings for the Clockstopper app.

    Naming convention
    ─────────────────
    btn_*      — button labels
    time_*     — time-display strings
    lap_*      — lap-list strings
    cd_*       — content descriptions for accessibility
-->
<resources>

    <!-- App-level -->
    <string name="app_name">ClockStopper</string>

    <!-- Stopwatch controls -->
    <string name="btn_start">Start</string>
    <string name="btn_stop">Stop</string>
    <string name="btn_lap">Lap</string>
    <string name="btn_reset">Reset</string>

    <!-- Time display — zeroed / initial state -->
    <string name="time_zero">00:00.00</string>

    <!-- Lap list -->
    <!-- %1$d is replaced with the 1-based lap number at runtime -->
    <string name="lap_number_label">Lap %1$d</string>

    <!-- Accessibility content descriptions -->
    <string name="cd_elapsed_time">Elapsed time display</string>
    <string name="cd_lap_list">Lap list</string>

</resources>
